generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssessmentStatus {
  IN_PROGRESS
  COMPLETED
}

enum Gender {
  FEMALE
  MALE
  NON_BINARY
}

enum Goal {
  LOSE_WEIGHT
  BUILD_STRENGTH
  IMPROVE_ENERGY
  INCREASE_FLEXIBILITY
}

enum ActivityLevel {
  LOW
  MODERATE
  HIGH
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  EXPIRED
}

enum PaymentEventStatus {
  SUCCESS
  FAILED
}

model AnonymousUser {
  id            String         @id @default(cuid())
  sessionToken  String         @unique @map("session_token")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  lastSeenAt    DateTime       @default(now()) @map("last_seen_at")
  assessments   Assessment[]
  subscription  Subscription?
  paymentEvents PaymentEvent[]

  @@map("anonymous_users")
}

model Assessment {
  id             String             @id @default(cuid())
  userId         String             @map("user_id")
  user           AnonymousUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         AssessmentStatus   @default(IN_PROGRESS)
  currentStep    String             @default("gender") @map("current_step")
  gender         Gender?
  goal           Goal?
  age            Int?
  heightCm       Float?             @map("height_cm")
  weightKg       Float?             @map("weight_kg")
  targetWeightKg Float?             @map("target_weight_kg")
  activityLevel  ActivityLevel?     @map("activity_level")
  version        Int                @default(0)
  submittedAt    DateTime?          @map("submitted_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  result         AssessmentResult?

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("assessments")
}

model AssessmentResult {
  id                    String     @id @default(cuid())
  assessmentId          String     @unique @map("assessment_id")
  assessment            Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  bmi                   Float
  bmiCategory           String     @map("bmi_category")
  bmr                   Float
  tdee                  Float
  suggestedCaloriesMin  Int        @map("suggested_calories_min")
  suggestedCaloriesMax  Int        @map("suggested_calories_max")
  targetDate            DateTime?  @map("target_date")
  summary               String
  unsafeTargetWarning   String?    @map("unsafe_target_warning")
  predictionCurve       Json       @map("prediction_curve")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")

  @@map("assessment_results")
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String             @unique @map("user_id")
  user      AnonymousUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    SubscriptionStatus @default(FREE)
  paidAt    DateTime?          @map("paid_at")
  expiresAt DateTime?          @map("expires_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model PaymentEvent {
  id          String             @id @default(cuid())
  userId      String             @map("user_id")
  user        AnonymousUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String            @map("session_token")
  type        String
  status      PaymentEventStatus
  rawPayload  Json               @map("raw_payload")
  createdAt   DateTime           @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("payment_events")
}
