# Supabase/Vercel runtime connection: use the pooled connection string.
# Supabase transaction pooler commonly uses port 6543.
DATABASE_URL="postgresql://USER.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres?schema=public"

# Prisma migration connection: use the direct database connection string.
# Supabase direct connection commonly uses port 5432.
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?schema=public"

# Optional for local demos and browser E2E without PostgreSQL.
# Production/demo deployments should use Prisma + PostgreSQL.
APP_DATA_MODE="memory"
